# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — get from https://console.anthropic.com/
# NOTE: In production, call Anthropic from a Supabase Edge Function, not the client.
# This is fine for dev/demo — see /supabase/functions/ask/index.ts
EXPO_PUBLIC_ANTHROPIC_KEY=sk-ant-...

# Google OAuth
# iOS client ID from Google Cloud Console
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=123456789-xxx.apps.googleusercontent.com
# Web client ID (needed for Supabase auth)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789-xxx.apps.googleusercontent.com
